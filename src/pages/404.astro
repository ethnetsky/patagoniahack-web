---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 - Access Denied">
	<main class="flex flex-col justify-center items-center text-center px-4 py-20">
		<h1 class="text-9xl font-bold text-red-600 animate-pulse">404</h1>
		<div class="font-mono mt-4 space-y-2">
			<p class="text-white text-xl uppercase tracking-widest">Error: Resource_Not_Found</p>
			<p class="text-slate-500 italic">// Acceso denegado a la ruta especificada</p>
		</div>
		<a href="/" class="mt-10 px-6 py-2 border border-red-600 text-red-600 hover:bg-red-600 hover:text-white transition-all font-mono">
			[ Volver al Root ]
		</a>
	</main>
</MainLayout>