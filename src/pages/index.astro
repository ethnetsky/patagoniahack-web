---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="PatagoniaHack | Seguridad e Infraestructura">
	<main class="flex flex-col items-center justify-center min-h-screen p-6">
		<div class="border border-[#00ff41]/20 p-10 bg-[#121212]/50 backdrop-blur-md rounded-sm max-w-3xl w-full shadow-[0_0_20px_rgba(0,255,65,0.05)]">
			
			<header class="mb-8">
				<h1 class="text-4xl md:text-6xl font-bold text-[#00ff41] tracking-tighter">
					PATAGONIA<span class="text-white">HACK</span>
				</h1>
				<div class="h-1 w-24 bg-[#00a8ff] mt-2"></div>
			</header>
			
			<section class="space-y-4 mb-10">
				<p class="text-gray-400 text-lg leading-relaxed">
					<span class="text-[#00ff41]">$</span> consultoria --area "seguridad_informatica"
				</p>
				<p class="text-white text-xl border-l-2 border-[#00a8ff] pl-4">
					Infraestructura Crítica & Desarrollo Seguro.
				</p>
				<p class="text-gray-500 italic">
					// Comodoro Rivadavia, Patagonia Argentina.
				</p>
			</section>

			<div class="flex flex-wrap gap-6">
				<a href="#" class="px-8 py-3 border border-[#00ff41] text-[#00ff41] hover:bg-[#00ff41] hover:text-black transition-all font-bold">
					INICIAR_SESION
				</a>
				<a href="#" class="px-8 py-3 text-[#00a8ff] hover:bg-[#00a8ff]/10 transition-all">
					VER_SERVICIOS
				</a>
			</div>
		</div>
		
		<footer class="mt-12 text-[10px] text-gray-700 uppercase tracking-[0.5em]">
			System Status: Stable // Node v24.15.0
		</footer>
	</main>
</MainLayout>