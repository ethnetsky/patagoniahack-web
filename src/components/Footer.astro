---
// Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-slate-900 bg-slate-950 py-12 px-4 mt-auto">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
    
    <div class="text-center md:text-left">
      <p class="font-mono text-xs text-red-600 font-bold tracking-widest mb-2">PATAGONIAHACK_CORE</p>
      <p class="text-slate-200 text-xs font-mono uppercase">
        Node: Comodoro Rivadavia, AR <br/>
        Lat: -45.86 | Long: -67.48
      </p>
    </div>

    <div class="text-center">
      <p class="text-slate-300 text-[15px] font-mono tracking-tighter">
        &copy; {new Date().getFullYear()} PATAGONIAHACK. ALL RIGHTS RESERVED.
      </p>
      <div class="flex justify-center gap-4 mt-4 opacity-50">
         <div class="h-1 w-8 bg-slate-800"></div>
         <div class="h-1 w-8 bg-red-900"></div>
         <div class="h-1 w-8 bg-slate-800"></div>
      </div>
    </div>

    <div class="text-center md:text-right font-mono text-[10px] text-slate-200">
      <p>ENV: PRODUCTION</p>
      <p>ENGINE: ASTRO v6.1.9</p>
      <p class="text-green-200">CONNECTION: ENCRYPTED</p>
    </div>

  </div>
</footer>
