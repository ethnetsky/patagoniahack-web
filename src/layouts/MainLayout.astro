---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="PatagoniaHack - Consultoría en Ciberseguridad" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-[#050505] text-white font-mono">
		<slot />
	</body>
</html>

<style is:global>
	/* Aquí es donde Tailwind se activa globalmente */
	@tailwind base;
	@tailwind components;
	@tailwind utilities;
</style>